{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chat-app",
  "version": "0.1.3",
  "identifier": "com.fromsko.chat-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "chat-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "fromsko",
    "homepage": "https://github.com/nextsko/tauri-tapps",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/nextsko/tauri-tapps/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5QjMyQzY3NjUxQ0E3MEMKUldRTXB4eGxaeXl6dVVWaFVMb01JR3Vtb0pTcTJKWllKK1d1eDJVaVlvQStnWUJiZlh5N0Rwb0cK"
    }
  }
}
